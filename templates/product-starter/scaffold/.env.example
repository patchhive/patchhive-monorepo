# ── Optional GitHub Access ────────────────────────────────────────────────────
# Suite-wide classic PAT used by PatchHive read paths.
# Recommended for public repositories: public_repo
# PATCHHIVE_GITHUB_TOKEN_RO=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional app auth ─────────────────────────────────────────────────────────
# __ENV_PREFIX___API_KEY_HASH=

# ── Storage ───────────────────────────────────────────────────────────────────
__ENV_PREFIX___DB_PATH=__DB_FILE__
__ENV_PREFIX___PORT=__BACKEND_PORT__

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
