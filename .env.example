# =============================================================================
# PatchHive unified environment
# =============================================================================
# Copy this file to .env at the repository root. Monorepo services and product
# binaries discover it automatically. Set PATCHHIVE_ENV_FILE to use a different
# canonical file. Existing process variables always override file values.

# ── Suite runtime ─────────────────────────────────────────────────────────────
PATCHHIVE_BIND_ADDR=127.0.0.1:8100
PATCHHIVE_DB_PATH=/mnt/docker/code/patchhive/data/patchhive.db
PATCHHIVE_PRODUCTS=all
PATCHHIVE_DB_POOL_SIZE=4
RUST_LOG=info

# ── Suite authentication and encryption ──────────────────────────────────────
# Shared secret used only for trusted product/bootstrap coordination.
# PATCHHIVE_SUITE_BOOTSTRAP_SECRET=
# Machine-random encryption key shared by products that encrypt local secrets.
# Generate with: openssl rand -hex 32
# PATCHHIVE_ENCRYPTION_KEY=
# PATCHHIVE_ALLOW_REMOTE_BOOTSTRAP=false

# ── Shared GitHub read path ───────────────────────────────────────────────────
# Recommended classic PAT: public_repo for public-only PatchHive use, or repo
# when private repositories are in scope. Add security_events when protected
# code-scanning/security-event reads require it.
#
# GitHub's classic PAT scopes are not truly read-only: public_repo and repo can
# authorize writes. PatchHive constrains this credential to read-client code
# paths and never uses it as a fallback for publishing.
# PATCHHIVE_GITHUB_TOKEN_RO=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Legacy compatibility only. Do not add these to new configurations.
# BOT_GITHUB_TOKEN=
# GITHUB_TOKEN=

# ── Product-specific GitHub write identities ─────────────────────────────────
# Publishing products must have their own explicit classic PAT. public_repo is
# recommended for public repositories; use repo only when private repositories
# are intentionally in scope. The shared read token never substitutes for these.
# MERGE_KEEPER_GITHUB_TOKEN_RW=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REVIEW_BEE_GITHUB_TOKEN_RW=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TRUST_GATE_GITHUB_TOKEN_RW=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REPO_REAPER_GITHUB_TOKEN_RW=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RepoReaper commit identity must match its write credential owner.
# BOT_GITHUB_USER=patchhive
# BOT_GITHUB_EMAIL=000000+patchhive@users.noreply.github.com

# ── Product operator and service authentication ──────────────────────────────
# Browser/operator API-key hashes.
# SIGNAL_API_KEY_HASH=
# TRUST_API_KEY_HASH=
# REPO_MEMORY_API_KEY_HASH=
# REVIEW_BEE_API_KEY_HASH=
# MERGE_KEEPER_API_KEY_HASH=
# FLAKE_STING_API_KEY_HASH=
# DEP_TRIAGE_API_KEY_HASH=
# VULN_TRIAGE_API_KEY_HASH=
# REFACTOR_SCOUT_API_KEY_HASH=
# RELEASE_SENTRY_API_KEY_HASH=
# REAPER_API_KEY_HASH=
# HIVE_CORE_API_KEY_HASH=

# Peer-service token hashes for HiveCore and product-to-product dispatch.
# SIGNAL_SERVICE_TOKEN_HASH=
# TRUST_SERVICE_TOKEN_HASH=
# REPO_MEMORY_SERVICE_TOKEN_HASH=
# REVIEW_BEE_SERVICE_TOKEN_HASH=
# MERGE_KEEPER_SERVICE_TOKEN_HASH=
# FLAKE_STING_SERVICE_TOKEN_HASH=
# DEP_TRIAGE_SERVICE_TOKEN_HASH=
# VULN_TRIAGE_SERVICE_TOKEN_HASH=
# REFACTOR_SCOUT_SERVICE_TOKEN_HASH=
# RELEASE_SENTRY_SERVICE_TOKEN_HASH=
# REAPER_SERVICE_TOKEN_HASH=

# ── GitHub webhooks and report links ─────────────────────────────────────────
# MERGE_KEEPER_GITHUB_WEBHOOK_SECRET=
# MERGE_KEEPER_PUBLIC_URL=http://localhost:5178
# REVIEW_BEE_GITHUB_WEBHOOK_SECRET=
# REVIEW_BEE_PUBLIC_URL=http://localhost:5177
# TRUST_GITHUB_WEBHOOK_SECRET=
# TRUSTGATE_PUBLIC_URL=http://localhost:5175
# WEBHOOK_SECRET=

# ── Product integrations ──────────────────────────────────────────────────────
# PATCHHIVE_REPO_MEMORY_URL=http://localhost:8100/api/products/repo-memory
# PATCHHIVE_REPO_MEMORY_API_KEY=
# PATCHHIVE_REVIEW_BEE_URL=http://localhost:8100/api/products/review-bee
# PATCHHIVE_REVIEW_BEE_API_KEY=
# PATCHHIVE_TRUST_GATE_URL=http://localhost:8100/api/products/trust-gate
# PATCHHIVE_TRUST_GATE_API_KEY=
# PATCHHIVE_HIVECORE_URL=http://localhost:8080
# PATCHHIVE_HIVECORE_SERVICE_TOKEN=
# PATCHHIVE_HIVECORE_API_KEY=

# ── RepoReaper AI and execution ───────────────────────────────────────────────
# PROVIDER_API_KEY=
# PATCHHIVE_AI_URL=http://localhost:4199
OLLAMA_BASE_URL=http://localhost:11434
COST_BUDGET_USD=0
MIN_REVIEW_CONFIDENCE=40
RETRY_COUNT=3
REAPER_MAX_ACTIVE_WORKERS=3
REAPER_ENABLE_UNTRUSTED_TESTS=false
# REAPER_TEST_SANDBOX=docker
# REAPER_ALLOW_HOST_TESTS=false
# REAPER_TEST_TIMEOUT_SECONDS=600
REAPER_DB_PATH=/mnt/docker/code/patchhive/products/repo-reaper/repo-reaper.db
REAPER_WORK_DIR=/tmp/repo-reaper
# REAPER_ENCRYPTION_KEY=

# ── Product-specific runtime settings ─────────────────────────────────────────
MERGE_KEEPER_REQUIRE_APPROVAL=true
SIGNAL_MARKER_REPO_LIMIT=10
REFACTOR_SCOUT_ALLOWED_ROOTS=/mnt/docker/code/patchhive
# REFACTOR_SCOUT_ALLOW_REMOTE_FS=false
# REFACTOR_SCOUT_CLONE_TIMEOUT_SECS=120

# HiveCore remains a separately hosted control plane until its engine migration.
HIVE_CORE_DB_PATH=/mnt/docker/code/patchhive/products/hive-core/hive-core.db
# HIVECORE_ENCRYPTION_KEY=
