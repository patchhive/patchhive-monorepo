# ── Shared GitHub Read Access ─────────────────────────────────────────────────
# Recommended classic PAT: public_repo for public repositories, or repo when
# private repositories are intentionally in scope. Add security_events when the
# token owner needs protected code-scanning/security-event reads.
# PATCHHIVE_GITHUB_TOKEN_RO=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional app auth ─────────────────────────────────────────────────────────
# VULN_TRIAGE_API_KEY_HASH=
# VULN_TRIAGE_SERVICE_TOKEN_HASH=

# ── Storage ───────────────────────────────────────────────────────────────────
VULN_TRIAGE_DB_PATH=vuln-triage.db
VULN_TRIAGE_PORT=8110

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
