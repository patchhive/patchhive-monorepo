# ── Shared GitHub Read Access ─────────────────────────────────────────────────
# Recommended classic PAT: public_repo for public repositories, or repo when
# private repositories are intentionally in scope. PatchHive constrains this
# credential to read-client code paths even though GitHub classic scopes are
# broader than true read-only access.
# PATCHHIVE_GITHUB_TOKEN_RO=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional app auth ─────────────────────────────────────────────────────────
# REFACTOR_SCOUT_API_KEY_HASH=
# REFACTOR_SCOUT_SERVICE_TOKEN_HASH=

# ── Storage ───────────────────────────────────────────────────────────────────
REFACTOR_SCOUT_DB_PATH=refactor-scout.db
REFACTOR_SCOUT_PORT=8090

# ── Filesystem scan safety ────────────────────────────────────────────────────
# Restrict scans to a path list such as /home/you/code:/srv/repos
# REFACTOR_SCOUT_ALLOWED_ROOTS=/home/you/code
# Allow authenticated remote clients to trigger filesystem scans
# REFACTOR_SCOUT_ALLOW_REMOTE_FS=true

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
