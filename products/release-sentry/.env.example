# ── Optional GitHub Access ────────────────────────────────────────────────────
# Recommended fine-grained PAT scopes:
# - Metadata: read
# - Contents: read
# - Actions: read
# - Issues: read
# - Deployments/Releases: read where available
# BOT_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional app auth ─────────────────────────────────────────────────────────
# RELEASE_SENTRY_API_KEY_HASH=
# RELEASE_SENTRY_SERVICE_TOKEN_HASH=

# ── Optional RepoMemory / FailGuard evidence ──────────────────────────────────
# PATCHHIVE_REPO_MEMORY_URL=http://localhost:8030
# PATCHHIVE_REPO_MEMORY_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
RELEASE_SENTRY_DB_PATH=release-sentry.db
RELEASE_SENTRY_PORT=8120

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
