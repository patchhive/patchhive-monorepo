# ── Shared GitHub Read Access ─────────────────────────────────────────────────
# Analysis uses the suite classic PAT: public_repo for public repositories, or
# repo when private repositories are intentionally in scope.
# PATCHHIVE_GITHUB_TOKEN_RO=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MergeKeeper GitHub Publishing ─────────────────────────────────────────────
# Publishing never falls back to the shared read credential. Use a dedicated
# classic PAT with public_repo, or repo only for intentional private-repo work.
# MERGE_KEEPER_GITHUB_TOKEN_RW=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MERGE_KEEPER_GITHUB_WEBHOOK_SECRET=replace-me
# MERGE_KEEPER_PUBLIC_URL=http://localhost:5178
# MERGE_KEEPER_REQUIRE_APPROVAL=true

# ── Optional app auth ─────────────────────────────────────────────────────────
# MERGE_KEEPER_API_KEY_HASH=
# MERGE_KEEPER_SERVICE_TOKEN_HASH=

# ── Optional PatchHive product integrations ───────────────────────────────────
# PATCHHIVE_REVIEW_BEE_URL=http://localhost:8040
# PATCHHIVE_REVIEW_BEE_API_KEY=
# PATCHHIVE_TRUST_GATE_URL=http://localhost:8020
# PATCHHIVE_TRUST_GATE_API_KEY=
# PATCHHIVE_REPO_MEMORY_URL=http://localhost:8030
# PATCHHIVE_REPO_MEMORY_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
MERGE_KEEPER_DB_PATH=merge-keeper.db
MERGE_KEEPER_PORT=8050

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
