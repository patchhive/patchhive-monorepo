# ── Optional GitHub Access ────────────────────────────────────────────────────
# Analysis-only fine-grained PAT: select each target repository and grant
# Metadata (read) and Pull requests (read). Actions (read) is useful for CI.
# For PAT-based publishing under the PatchHive identity, grant that account
# write access to the repository and use a classic PAT with `public_repo` for
# public repositories (`repo` for private repositories). MergeKeeper publishes
# a commit status and maintained PR comment. Native check runs require a
# GitHub App installation token and are attempted before the status fallback.
# BOT_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MERGE_KEEPER_GITHUB_WEBHOOK_SECRET=replace-me
# MERGE_KEEPER_PUBLIC_URL=http://localhost:5178
# Require one active approval before a clean PR can be called ready.
# Manual UI runs can override this per assessment.
# MERGE_KEEPER_REQUIRE_APPROVAL=true

# ── Optional app auth ─────────────────────────────────────────────────────────
# MERGE_KEEPER_API_KEY_HASH=
# MERGE_KEEPER_SERVICE_TOKEN_HASH=

# ── Optional PatchHive product integrations ───────────────────────────────────
# PATCHHIVE_REVIEW_BEE_URL=http://localhost:8040
# PATCHHIVE_REVIEW_BEE_API_KEY=
# PATCHHIVE_TRUST_GATE_URL=http://localhost:8020
# PATCHHIVE_TRUST_GATE_API_KEY=
# PATCHHIVE_REPO_MEMORY_URL=http://localhost:8030
# PATCHHIVE_REPO_MEMORY_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
MERGE_KEEPER_DB_PATH=merge-keeper.db
MERGE_KEEPER_PORT=8050

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
