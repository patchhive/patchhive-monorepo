# ── Optional GitHub Access ────────────────────────────────────────────────────
# Recommended fine-grained PAT:
# Metadata (read), Pull requests (read), Dependabot alerts (read).
# Pull-request reads power update triage; Dependabot alerts add security urgency.
# BOT_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional app auth ─────────────────────────────────────────────────────────
# DEP_TRIAGE_API_KEY_HASH=
# DEP_TRIAGE_SERVICE_TOKEN_HASH=

# ── Storage ───────────────────────────────────────────────────────────────────
DEP_TRIAGE_DB_PATH=dep-triage.db
DEP_TRIAGE_PORT=8070

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
