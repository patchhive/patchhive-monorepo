# ── Optional GitHub Access ────────────────────────────────────────────────────
# Analysis-only fine-grained PAT:
# Metadata (read), Pull requests (read).
# For full GitHub reporting, also grant Checks (write), Commit statuses (write),
# and Issues (write) so TrustGate can publish results back to pull requests.
# BOT_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TRUST_GITHUB_WEBHOOK_SECRET=replace-me
# TRUSTGATE_PUBLIC_URL=https://trustgate.your-domain.example
# PATCHHIVE_REPO_MEMORY_URL=http://localhost:8030
# PATCHHIVE_REPO_MEMORY_API_KEY=

# ── Optional app auth ─────────────────────────────────────────────────────────
# TRUST_API_KEY_HASH=
# TRUST_SERVICE_TOKEN_HASH=

# ── Storage ───────────────────────────────────────────────────────────────────
TRUST_DB_PATH=trust-gate.db
TRUSTGATE_PORT=8020

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
