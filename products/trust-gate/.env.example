# ── Shared GitHub Read Access ─────────────────────────────────────────────────
# PR-diff reads use the suite classic PAT: public_repo for public repositories,
# or repo when private repositories are intentionally in scope.
# PATCHHIVE_GITHUB_TOKEN_RO=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TrustGate GitHub Publishing ───────────────────────────────────────────────
# Publishing never falls back to the shared read credential. Use a dedicated
# classic PAT with public_repo, or repo only for intentional private-repo work.
# TRUST_GATE_GITHUB_TOKEN_RW=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TRUST_GITHUB_WEBHOOK_SECRET=replace-me
# TRUSTGATE_PUBLIC_URL=https://trustgate.your-domain.example
# PATCHHIVE_REPO_MEMORY_URL=http://localhost:8030
# PATCHHIVE_REPO_MEMORY_API_KEY=

# ── Optional app auth ─────────────────────────────────────────────────────────
# TRUST_API_KEY_HASH=
# TRUST_SERVICE_TOKEN_HASH=

# ── Storage ───────────────────────────────────────────────────────────────────
TRUST_DB_PATH=trust-gate.db
TRUSTGATE_PORT=8020

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
