# ── Shared GitHub Read Access ─────────────────────────────────────────────────
# Recommended classic PAT: public_repo for public repositories, or repo when
# private repositories are intentionally in scope. PatchHive constrains this
# credential to read-client code paths even though GitHub classic scopes are
# broader than true read-only access.
# PATCHHIVE_GITHUB_TOKEN_RO=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional app auth ─────────────────────────────────────────────────────────
# SIGNAL_API_KEY_HASH=
# SIGNAL_SERVICE_TOKEN_HASH=
# Set this with ./scripts/set-signal-api-key.sh if you want to keep your own
# SignalHive password in a password manager and use it from multiple devices.
# PATCHHIVE_ALLOW_REMOTE_BOOTSTRAP=true

# ── Storage ───────────────────────────────────────────────────────────────────
SIGNAL_DB_PATH=signal-hive.db
SIGNAL_PORT=8010

# ── Scan tuning ───────────────────────────────────────────────────────────────
# SignalHive caps TODO/FIXME code search to the top-ranked repos in each scan
# so GitHub code-search limits do not drown wider scans.
SIGNAL_MARKER_REPO_LIMIT=4

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
