# ── Shared GitHub Read Access ─────────────────────────────────────────────────
# Analysis uses the suite classic PAT: public_repo for public repositories, or
# repo when private repositories are intentionally in scope.
# PATCHHIVE_GITHUB_TOKEN_RO=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ReviewBee GitHub Publishing ───────────────────────────────────────────────
# Maintained comments never fall back to the shared read credential. Use a
# dedicated classic PAT with public_repo, or repo for intentional private scope.
# REVIEW_BEE_GITHUB_TOKEN_RW=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REVIEW_BEE_GITHUB_WEBHOOK_SECRET=super-secret
# REVIEW_BEE_PUBLIC_URL=http://localhost:5177

# ── Optional app auth ─────────────────────────────────────────────────────────
# REVIEW_BEE_API_KEY_HASH=
# REVIEW_BEE_SERVICE_TOKEN_HASH=

# ── Storage ───────────────────────────────────────────────────────────────────
REVIEW_BEE_DB_PATH=review-bee.db
REVIEW_BEE_PORT=8040

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
