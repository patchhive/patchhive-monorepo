# ── Optional GitHub Access ────────────────────────────────────────────────────
# Recommended fine-grained PAT:
# Metadata (read), Actions (read).
# This improves workflow-run and job reads, especially on private repos.
# BOT_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional app auth ─────────────────────────────────────────────────────────
# FLAKE_STING_API_KEY_HASH=
# FLAKE_STING_SERVICE_TOKEN_HASH=

# ── Storage ───────────────────────────────────────────────────────────────────
FLAKE_STING_DB_PATH=flake-sting.db
FLAKE_STING_PORT=8060

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
